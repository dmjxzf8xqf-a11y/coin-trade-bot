def enhance_entry_with_ai(symbol: str, side: str, mp: dict, ohlcv: list):
    regime = detect_market_regime_from_ohlcv(ohlcv)
    strategy = select_strategy(regime)
    base_enter_score = float(mp.get("enter_score", 60))
    ai_enter_score = compute_ai_enter_score(symbol=symbol, side=side, strategy=strategy, regime=regime, base_enter_score=base_enter_score)
    blocked, reason = should_block_trade(symbol=symbol, side=side, strategy=strategy, regime=regime, enter_score=ai_enter_score)
    if blocked:
        return {"ok": False, "reason": reason, "regime": regime, "strategy": strategy, "enter_score": ai_enter_score, "size_usdt": 0.0}
    base_usdt = float(mp.get("base_usdt", 50))
    size_usdt = adapt_position_size(base_usdt, ai_enter_score, regime)
    mp["regime"] = regime
    mp["strategy"] = strategy
    mp["enter_score"] = ai_enter_score
    mp["base_usdt"] = size_usdt
    return {"ok": True, "reason": "AI 통과", "regime": regime, "strategy": strategy, "enter_score": ai_enter_score, "size_usdt": size_usdt}

