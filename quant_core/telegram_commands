# trader.py에서 명령 처리부를 쪼개기 위한 보조 함수 모음
from status_formatter import format_status_text
from telegram_ui import build_keyboard, remove_keyboard


def cmd_start(bot):
    bot.trading_enabled = True
    bot.state["trading_enabled"] = True
    bot.notify("✅ 거래 ON")


def cmd_stop(bot):
    bot.trading_enabled = False
    bot.state["trading_enabled"] = False
    bot.notify("🛑 거래 OFF")


def cmd_status(bot):
    if bot.state.get("tg_buttons_on", False):
        bot.tg_send(format_status_text(bot.state), reply_markup=build_keyboard())
    else:
        bot.notify(format_status_text(bot.state))


def cmd_ui(bot, arg: str):
    on = (arg or "").lower() in ("on", "1", "true", "yes", "y")
    bot.state["tg_buttons_on"] = on
    if on:
        bot.tg_send("🧩 UI ON", reply_markup=build_keyboard())
    else:
        bot.tg_send("🧩 UI OFF", reply_markup=remove_keyboard())
